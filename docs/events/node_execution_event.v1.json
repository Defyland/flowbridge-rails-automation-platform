{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Defyland/flowbridge-rails-automation-platform/docs/events/node_execution_event.v1.json",
  "title": "FlowBridge Node Execution Event v1",
  "type": "object",
  "required": ["event_id", "event_type", "schema_version", "occurred_at", "producer", "organization_id", "workflow_id", "workflow_version_id", "execution_id", "source", "correlation_id", "payload"],
  "properties": {
    "event_id": { "type": "string" },
    "event_type": { "type": "string", "enum": ["workflow.node.started", "workflow.node.succeeded", "workflow.node.failed", "workflow.node.skipped", "workflow.node.retrying"] },
    "schema_version": { "type": "integer", "const": 1 },
    "occurred_at": { "type": "string", "format": "date-time" },
    "producer": { "type": "string", "const": "flowbridge" },
    "organization_id": { "type": "string" },
    "workflow_id": { "type": "string" },
    "workflow_version_id": { "type": "string" },
    "execution_id": { "type": "string" },
    "source": { "type": "string" },
    "source_event_id": { "type": ["string", "null"] },
    "correlation_id": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["node_key", "node_type", "attempt", "duration_ms"],
      "properties": {
        "node_key": { "type": "string" },
        "node_type": { "type": "string" },
        "attempt": { "type": "integer", "minimum": 1 },
        "duration_ms": { "type": ["integer", "null"], "minimum": 0 },
        "input": { "type": ["object", "null"] },
        "output": { "type": ["object", "null"] },
        "error": { "type": ["object", "null"] }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
