<div class="auth">
  <section class="auth-card">
    <h1>Reset password</h1>
    <p>Send reset instructions to an operator account.</p>

    <%= form_with url: passwords_path do |form| %>
      <div class="field">
        <%= form.label :email_address, "Email" %>
        <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", value: params[:email_address] %>
      </div>
      <%= form.submit "Email reset instructions", class: "button" %>
    <% end %>
  </section>
</div>
